---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/paths';

const EC_URL = 'https://isshin-dev.github.io/woodtile_ec/';

const products = [
  { name: '市松', desc: '杉柾目・オイル仕上げ', image: withBase('/images/mokuri/product-01.png') },
  { name: '矢羽根', desc: '檜・浮造り仕上げ', image: withBase('/images/mokuri/product-02.png') },
  { name: '網代', desc: '杉赤身・柿渋染め', image: withBase('/images/mokuri/product-03.png') },
  { name: 'ヘリンボーン', desc: 'ナラ・蜜蝋ワックス', image: withBase('/images/mokuri/product-04.png') },
  { name: '乱貼り', desc: '混合樹種・無塗装', image: withBase('/images/mokuri/product-05.png') },
  { name: 'モザイク', desc: '端材再生・漆拭き仕上げ', image: withBase('/images/mokuri/product-06.png') },
];
---

<BaseLayout
  title="MOKURI｜カスタムメイド木製タイルブランド - KIILA株式会社"
  description="MOKURIは、空間に合わせて一枚から設計できるカスタムメイドの木製タイルブランドです。杉・檜など日本の木と、漆・柿渋など伝統の仕上げを、現代の空間へ。"
>
  <!-- ヒーロー（cream color-block） -->
  <section class="section-tight">
    <div class="container">
      <div class="color-block block-cream hero">
        <div class="hero-copy">
          <p class="eyebrow eyebrow-mark">MOKURI — Custom Wood Tile</p>
          <h1 class="display-xl hero-title">木の表情を、<br />空間の主役に。</h1>
          <p class="body-lg hero-lead">空間に合わせて一枚から設計する、カスタムメイドの木製タイルブランド。</p>
          <a class="btn btn-primary" href="#order">設計ツールを開く</a>
        </div>
        <div class="hero-visual frame">
          <img src={withBase('/images/mokuri/hero.png')} alt="MOKURIの木製タイルが貼られた壁面" />
        </div>
      </div>
    </div>
  </section>

  <!-- ブランドストーリー -->
  <section class="section">
    <div class="container story">
      <div class="story-text">
        <p class="eyebrow">Story</p>
        <h2 class="display-lg story-title">木と、手と、機械と。</h2>
        <p class="body story-p">
          同じ山の杉でも、一本ごとに木目は違い、一枚ごとに表情が変わります。
          MOKURIは、その揺らぎこそが空間の豊かさだと考えます。
        </p>
        <p class="body story-p">
          素材は、杉や檜をはじめとする日本の木。仕上げには、漆や柿渋、蜜蝋といった
          先人たちが磨いてきた知恵を借りながら、CNCルーターによる精密な加工を掛け合わせ、
          伝統と技術のあいだにある「ちょうどよい手ざわり」を探しています。
        </p>
        <p class="body story-p">
          壁一面のアートウォールから、店舗のサイン、住まいのワンポイントまで。
          空間の寸法に合わせて、パターン・樹種・仕上げをひとつずつ設計します。
        </p>
      </div>
      <div class="story-image frame">
        <img src={withBase('/images/mokuri/story.png')} alt="木製タイルの制作風景" />
      </div>
    </div>
  </section>

  <!-- プロダクトショーケース -->
  <section class="section-tight">
    <div class="container">
      <div class="products-head">
        <p class="eyebrow">Products</p>
        <h2 class="display-lg">パターンショーケース</h2>
        <p class="subhead products-lead">
          代表的なパターンの一例です。樹種・サイズ・仕上げはすべてカスタマイズできます。
        </p>
      </div>
      <div class="product-grid">
        {
          products.map((p) => (
            <figure class="product tile">
              <div class="product-thumb frame">
                <img src={p.image} alt={`木製タイル ${p.name}`} />
              </div>
              <figcaption>
                <p class="card-title product-name">{p.name}</p>
                <p class="caption product-desc">{p.desc}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ECサイトへの導線（lime color-block） -->
  <section class="section-tight" id="order">
    <div class="container">
      <div class="color-block block-lime order">
        <p class="eyebrow eyebrow-mark">Order</p>
        <h2 class="display-lg order-title">オンラインで、<br />あなたのタイルを設計する。</h2>
        <p class="body order-lead">
          オーダータイル設計ツールで、パターンやサイズを選びながら、
          オリジナルの木製タイルをその場で設計・注文できます。
        </p>
        <a class="btn btn-primary" href={EC_URL} target="_blank" rel="noopener noreferrer">
          設計ツールを開く（別タブ）
        </a>

        <!--
          ECサイトへの導線は「別タブで開くボタン（上）」と「iframe埋め込み（下）」の
          両方を実装。どちらかに絞る場合は不要な方のブロックを削除する。
        -->
        <div class="order-embed">
          <p class="caption order-embed-note">ページ内でそのまま試す</p>
          <div class="order-frame frame">
            <iframe src={EC_URL} title="MOKURI オーダータイル設計ツール" loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- クロージングCTA（pink color-block） -->
  <section class="section-tight">
    <div class="container">
      <div class="color-block block-pink cta">
        <h2 class="display-lg cta-title">空間に合わせた木製タイルの<br />ご相談を承ります。</h2>
        <p class="subhead cta-lead">図面がなくても、イメージの段階からご一緒します。</p>
        <div class="cta-actions">
          <a class="btn btn-primary" href={EC_URL} target="_blank" rel="noopener noreferrer">設計ツールで注文する</a>
          <a class="btn btn-secondary" href={withBase('/gordix/#contact')}>問い合わせる</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- hero ---------- */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-title {
    margin: 22px 0 22px;
  }
  .hero-lead {
    margin-bottom: 32px;
    max-width: 420px;
  }
  .hero-visual {
    aspect-ratio: 4 / 3;
  }

  /* ---------- story ---------- */
  .story {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  .story-title {
    margin: 14px 0 28px;
  }
  .story-p {
    margin-bottom: 20px;
    max-width: 520px;
  }
  .story-image {
    aspect-ratio: 4 / 3;
  }

  /* ---------- products ---------- */
  .products-head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 40px;
  }
  .products-lead {
    max-width: 640px;
    margin-top: 8px;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .product {
    margin: 0;
  }
  .product-thumb {
    aspect-ratio: 1 / 1;
    margin-bottom: 14px;
  }
  .product-name {
    font-size: 20px;
  }
  .product-desc {
    margin-top: 6px;
    opacity: 0.7;
  }

  /* ---------- order ---------- */
  .order-title {
    margin: 20px 0 20px;
  }
  .order-lead {
    max-width: 560px;
    margin-bottom: 28px;
  }
  .order-embed {
    margin-top: 40px;
  }
  .order-embed-note {
    margin-bottom: 12px;
    opacity: 0.7;
  }
  .order-frame {
    background: var(--canvas);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }
  .order-frame iframe {
    display: block;
    width: 100%;
    height: 720px;
    border: 0;
  }

  /* ---------- cta ---------- */
  .cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cta-lead {
    margin: 20px 0 32px;
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 960px) {
    .hero,
    .story {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .order-frame iframe {
      height: 560px;
    }
  }
  @media (max-width: 520px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
