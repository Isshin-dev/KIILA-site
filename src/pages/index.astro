---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';

const values = [
  { label: 'Mission', text: '森の価値を最大化し、人の暮らしと産業に新しい価値を生み出す。' },
  { label: 'Vision', text: '木とテクノロジーが当たり前に共存する、豊かな未来をつくる。' },
  { label: 'Value', text: '誠実に、つくることに向き合い、ひと・自然・技術のつながりを育む。' },
];

// お知らせはダミー。正式運用時に差し替え
const news = [
  { date: '2026.06.20', tag: 'MOKURI', title: '新作木製タイル「MORI」シリーズを追加しました', image: withBase('/images/kiila/news-01.png') },
  { date: '2026.06.02', tag: 'GORDIX', title: 'GORDIX導入セミナー（東京）開催レポート', image: withBase('/images/kiila/news-02.png') },
  { date: '2026.05.24', tag: 'MOKURI', title: '展示施設向け事例を3件追加しました', image: withBase('/images/kiila/news-03.png') },
  { date: '2026.05.10', tag: 'NEWS', title: 'KIILA株式会社 コーポレートサイトを公開しました', image: withBase('/images/kiila/news-04.png') },
];

const marquee = [
  'MOKURI — CUSTOM WOOD TILE',
  'GORDIX — 3-IN-1 PORTABLE CNC',
  "KIILA = FINNISH FOR ‘WEDGE’",
  '森と技術をつなぐ',
];
---

<BaseLayout title="KIILA株式会社｜常識に楔を、木と技術で未来を組み直す">
  <!-- ヒーロー -->
  <section class="section hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow eyebrow-mark">KIILA — Finnish for “Wedge”</p>
        <h1 class="display-xl hero-title">常識に、楔を。<br />木と技術で、<br />未来を組み直す。</h1>
        <p class="body-lg hero-lead">
          KIILA株式会社は、既存の概念に楔を打ち込み、新しいものを組み立て直す会社です。
          カスタム木製タイルブランド「MOKURI」と、CNCルーター「GORDIX」の普及を通じて、
          人と森、デザインと技術をつなぐ未来をつくります。
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={withBase('/mokuri/')}>MOKURIを見る</a>
          <a class="btn btn-secondary" href={withBase('/gordix/')}>GORDIXを見る</a>
        </div>
      </div>
      <div class="hero-visual frame">
        <img src={withBase('/images/kiila/hero-main.png')} alt="CNCルーターによる木材加工" />
      </div>
    </div>
  </section>

  <!-- マーキー -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {marquee.map((m) => <span>{m}</span>)}
      {marquee.map((m) => <span>{m}</span>)}
    </div>
  </div>

  <!-- 会社概要 -->
  <section class="section" id="about">
    <div class="container">
      <div class="about-head">
        <p class="eyebrow">About</p>
        <h2 class="display-lg">KIILA株式会社について</h2>
      </div>
      <p class="subhead about-lead">
        KIILAはフィンランド語で「楔」。硬い丸太も、正しい一点に楔を打てば割り開くことができます。
        私たちは、自然の恵みである「木」と、進化する「技術」を掛け合わせ、持続可能で心地よい社会をつくります。
      </p>
      <div class="values">
        {
          values.map((v) => (
            <div class="value">
              <p class="eyebrow value-label">{v.label}</p>
              <p class="body value-text">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 事業A: MOKURI（cream color-block） -->
  <section class="section-tight" id="business">
    <div class="container">
      <div class="color-block block-cream biz">
        <div class="biz-copy">
          <p class="eyebrow eyebrow-mark">事業A — MOKURI</p>
          <h3 class="display-lg biz-title">木の表情を、<br />空間の主役に。</h3>
          <p class="body biz-text">
            木の美しさと、デザインの自由度を。空間に合わせたオリジナルの木製タイルを、
            一枚から企画・設計・製作するカスタムメイドブランドです。
          </p>
          <a class="btn btn-primary" href={withBase('/mokuri/')}>MOKURIを見る</a>
        </div>
        <div class="biz-visual frame">
          <img src={withBase('/images/kiila/business-mokuri.png')} alt="MOKURIの木製タイル" />
        </div>
      </div>
    </div>
  </section>

  <!-- 事業B: GORDIX（navy color-block） -->
  <section class="section-tight">
    <div class="container">
      <div class="color-block block-navy biz">
        <div class="biz-copy">
          <p class="eyebrow eyebrow-mark">事業B — GORDIX</p>
          <h3 class="display-lg biz-title">削るを、<br />みんなのものに。</h3>
          <p class="body biz-text">
            CNCルーター「GORDIX」の導入支援と、ノウハウ・コミュニティ運営を通じて、
            教育機関を中心にデジタルものづくりの可能性を広げます。
          </p>
          <a class="btn btn-white" href={withBase('/gordix/')}>GORDIXを見る</a>
        </div>
        <div class="biz-visual frame">
          <img src={withBase('/images/kiila/business-gordix.png')} alt="CNCルーターGORDIX" />
        </div>
      </div>
    </div>
  </section>

  <!-- お知らせ -->
  <section class="section" id="news">
    <div class="container">
      <div class="news-head">
        <div>
          <p class="eyebrow">News</p>
          <h2 class="display-lg">お知らせ</h2>
        </div>
        <a class="link-underline" href="#news">お知らせ一覧</a>
      </div>
      <div class="news-grid">
        {
          news.map((item) => (
            <a class="news-card tile" href="#news">
              <div class="news-thumb frame">
                <img src={item.image} alt="" />
              </div>
              <span class="chip news-chip">{item.tag}</span>
              <p class="body-sm news-title">{item.title}</p>
              <time class="caption news-date">{item.date}</time>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- クロージングCTA（lime color-block） -->
  <section class="section-tight">
    <div class="container">
      <div class="color-block block-lime cta">
        <h2 class="display-lg cta-title">森と技術で、<br />あなたの想いをかたちに。</h2>
        <p class="subhead cta-lead">まずはお気軽にご相談ください。</p>
        <div class="cta-actions">
          <a class="btn btn-primary" href={withBase('/mokuri/')}>MOKURIを相談する</a>
          <a class="btn btn-secondary" href={withBase('/gordix/#contact')}>GORDIXを相談する</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- hero ---------- */
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: 56px;
  }
  .hero-title {
    margin-top: 24px;
  }
  .hero-lead {
    margin-top: 28px;
    max-width: 520px;
  }
  .hero-actions {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .hero-visual {
    aspect-ratio: 4 / 3;
  }

  /* ---------- about ---------- */
  .about-head {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .about-lead {
    max-width: 780px;
    margin: 32px 0 56px;
  }
  .values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    border-top: 1px solid var(--hairline);
    padding-top: 40px;
  }
  .value-label {
    margin-bottom: 14px;
  }

  /* ---------- business color blocks ---------- */
  .biz {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .biz-title {
    margin: 20px 0 20px;
  }
  .biz-text {
    margin-bottom: 32px;
    max-width: 440px;
  }
  .biz-visual {
    aspect-ratio: 4 / 3;
  }

  /* ---------- news ---------- */
  .news-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
  }
  .news-head .display-lg {
    margin-top: 12px;
  }
  .news-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .news-card {
    display: flex;
    flex-direction: column;
    transition: transform 0.18s ease;
  }
  .news-card:hover {
    transform: translateY(-3px);
  }
  .news-thumb {
    aspect-ratio: 4 / 3;
    margin-bottom: 16px;
  }
  .news-chip {
    align-self: flex-start;
  }
  .news-title {
    margin-top: 12px;
    font-weight: 500;
  }
  .news-date {
    margin-top: 12px;
    opacity: 0.6;
  }

  /* ---------- closing cta ---------- */
  .cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cta-lead {
    margin: 20px 0 32px;
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  /* ---------- responsive ---------- */
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .values {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .biz {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
