---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';

const values = [
  {
    label: 'Mission',
    text: '森の価値を最大化し、人の暮らしと産業に新しい価値を生み出す。',
  },
  {
    label: 'Vision',
    text: '木とテクノロジーが当たり前に共存する豊かな未来をつくる。',
  },
  {
    label: 'Value',
    text: '誠実に、つくることに向き合い、ひと・自然・技術のつながりを育む事業を続ける。',
  },
];

// お知らせはダミー。正式運用時に差し替え
const news = [
  {
    date: '2026.06.20',
    tag: 'MOKURI',
    title: '新作木製タイル「MORI」シリーズを追加しました',
    image: withBase('/images/kiila/news-01.png'),
  },
  {
    date: '2026.06.02',
    tag: 'GORDIX',
    title: 'GORDIX導入セミナー（東京）開催レポート',
    image: withBase('/images/kiila/news-02.png'),
  },
  {
    date: '2026.05.24',
    tag: 'MOKURI',
    title: '展示施設向け事例を3件追加しました',
    image: withBase('/images/kiila/news-03.png'),
  },
  {
    date: '2026.05.10',
    tag: 'お知らせ',
    title: 'KIILA株式会社 コーポレートサイトを公開しました',
    image: withBase('/images/kiila/news-04.png'),
  },
];
---

<BaseLayout title="KIILA株式会社｜木の可能性で、空間と未来をデザインする">
  <!-- ヒーロー -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-eyebrow">KIILA — フィンランド語で「楔（くさび）」</p>
        <h1 class="hero-title">
          常識に、<span>楔</span>を。<br />
          木と技術で、<span>未来</span>を組み直す。
        </h1>
        <p class="hero-lead">
          KIILA株式会社は、既存の概念に楔を打ち込み、新しいものを組み立て直す会社です。
          カスタム木製タイルブランド「MOKURI」と、CNCルーター「GORDIX」の普及を通じて、
          人と森、デザインと技術をつなぐ未来をつくります。
        </p>
        <div class="hero-buttons">
          <a class="btn" href={withBase('/mokuri/')}>MOKURIを見る</a>
          <a class="btn btn-outline" href={withBase('/gordix/')}>GORDIXを見る</a>
        </div>
      </div>
      <div class="hero-visual">
        <img src={withBase('/images/kiila/hero-main.png')} alt="CNCルーターによる木材加工" />
        <img class="hero-visual-sub" src={withBase('/images/kiila/hero-sub.png')} alt="木製タイルの壁面" />
      </div>
    </div>
  </section>

  <!-- 会社概要 -->
  <section class="section" id="about">
    <div class="container about-grid">
      <div>
        <p class="section-eyebrow">About</p>
        <h2 class="section-title">KIILA株式会社について</h2>
        <p class="section-lead">
          KIILAはフィンランド語で「楔」。硬い丸太も、正しい一点に楔を打てば割り開くことができます。
          私たちは、自然の恵みである「木」と、進化する「技術」を掛け合わせることで、
          持続可能で心地よい社会をつくります。
        </p>
      </div>
      <div class="value-cards">
        {
          values.map((v) => (
            <div class="card value-card">
              <p class="value-label">{v.label}</p>
              <p class="value-text">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2つの事業 -->
  <section class="section section-alt" id="business">
    <div class="container">
      <p class="section-eyebrow">Business</p>
      <h2 class="section-title">2つの事業</h2>
      <div class="business-grid">
        <div class="business-card">
          <img src={withBase('/images/kiila/business-mokuri.png')} alt="MOKURIの木製タイル" />
          <div class="business-body">
            <span class="tag tag-green">事業A</span>
            <h3>MOKURI — カスタム木製タイルブランド</h3>
            <p>
              木の美しさと、デザインの自由度を。
              空間に合わせたオリジナルの木製タイルを、一枚から企画・設計・製作します。
            </p>
            <a class="btn" href={withBase('/mokuri/')}>MOKURIを見る</a>
          </div>
        </div>
        <div class="business-card">
          <img src={withBase('/images/kiila/business-gordix.png')} alt="CNCルーターGORDIX" />
          <div class="business-body">
            <span class="tag tag-green">事業B</span>
            <h3>GORDIX普及事業</h3>
            <p>
              CNCルーター「GORDIX」の導入支援と、使いこなしのためのドキュメント・コミュニティ運営を通じて、
              教育機関を中心にデジタルものづくりの可能性を広げます。
            </p>
            <a class="btn" href={withBase('/gordix/')}>GORDIXを見る</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- お知らせ -->
  <section class="section" id="news">
    <div class="container">
      <div class="news-head">
        <div>
          <p class="section-eyebrow">News</p>
          <h2 class="section-title">お知らせ</h2>
        </div>
        <a class="news-more" href="#news">お知らせ一覧 →</a>
      </div>
      <div class="news-grid">
        {
          news.map((item) => (
            <article class="news-card">
              <img src={item.image} alt="" />
              <div class="news-body">
                <span class="tag">{item.tag}</span>
                <p class="news-title">{item.title}</p>
                <time class="news-date">{item.date}</time>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="container cta-band-inner">
      <p class="cta-band-text">
        森と技術で、あなたの想いをかたちにします。<br />
        まずはお気軽にご相談ください。
      </p>
      <div class="cta-band-buttons">
        <a class="btn btn-white" href={withBase('/mokuri/')}>MOKURIについて相談する</a>
        <a class="btn btn-white-outline" href={withBase('/gordix/#contact')}>GORDIXについて相談する</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- ヒーロー ---------- */
  .hero {
    background: linear-gradient(135deg, #fdfcf9 0%, var(--bg) 60%, var(--bg-soft) 100%);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 56px;
    padding-block: 88px;
  }

  .hero-eyebrow {
    font-size: 13px;
    letter-spacing: 0.2em;
    color: var(--green);
    margin-bottom: 20px;
  }

  .hero-title {
    font-size: clamp(30px, 3.2vw, 40px);
    font-weight: 700;
    line-height: 1.6;
    letter-spacing: 0.06em;
  }

  .hero-title span {
    color: var(--green);
  }

  .hero-lead {
    margin-top: 28px;
    color: var(--muted);
    max-width: 520px;
  }

  .hero-buttons {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .hero-visual {
    position: relative;
  }

  .hero-visual > img:first-child {
    border-radius: var(--radius);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    clip-path: polygon(8% 0, 100% 0, 100% 100%, 0 100%);
  }

  .hero-visual-sub {
    position: absolute;
    left: -36px;
    bottom: -40px;
    width: 38%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius);
    border: 6px solid #fff;
    box-shadow: 0 10px 30px rgba(38, 36, 31, 0.15);
  }

  /* ---------- 会社概要 ---------- */
  .about-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 56px;
    align-items: start;
  }

  .value-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .value-label {
    font-family: var(--font-en);
    font-size: 19px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--green);
    margin-bottom: 14px;
  }

  .value-text {
    font-size: 14px;
    color: var(--ink);
  }

  /* ---------- 事業 ---------- */
  .business-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 24px;
  }

  .business-card {
    background: var(--card);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(38, 36, 31, 0.06);
    display: flex;
    flex-direction: column;
  }

  .business-card > img {
    aspect-ratio: 16 / 9;
    object-fit: cover;
    width: 100%;
  }

  .business-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    flex: 1;
  }

  .business-body h3 {
    font-size: 21px;
  }

  .business-body p {
    color: var(--muted);
    font-size: 14px;
    flex: 1;
  }

  /* ---------- お知らせ ---------- */
  .news-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }

  .news-more {
    font-size: 13px;
    letter-spacing: 0.1em;
    color: var(--green);
    padding-bottom: 28px;
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .news-card {
    background: var(--card);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(38, 36, 31, 0.06);
  }

  .news-card img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
  }

  .news-body {
    padding: 18px 18px 22px;
  }

  .news-title {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.8;
    margin-top: 10px;
  }

  .news-date {
    display: block;
    font-family: var(--font-en);
    font-size: 12px;
    color: var(--muted);
    margin-top: 10px;
    letter-spacing: 0.08em;
  }

  /* ---------- レスポンシブ ---------- */
  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
      padding-block: 56px;
    }

    .hero-title {
      font-size: 32px;
    }

    .hero-visual-sub {
      left: -12px;
      bottom: -24px;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .value-cards {
      grid-template-columns: 1fr;
    }

    .business-grid {
      grid-template-columns: 1fr;
    }

    .news-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
