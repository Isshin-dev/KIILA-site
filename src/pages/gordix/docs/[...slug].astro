---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { withBase, formatDate } from '../../../lib/paths';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

const categoryLabel: Record<string, string> = {
  manual: 'マニュアル',
  case: '導入事例',
  news: 'お知らせ',
};
---

<BaseLayout title={`${doc.data.title}｜GORDIX ドキュメント - KIILA株式会社`} description={doc.data.description}>
  <article class="section">
    <div class="container doc-container">
      <a class="doc-back" href={withBase('/gordix/#docs')}>← ドキュメント一覧へ戻る</a>
      <header class="doc-header">
        <span class="tag tag-green">{categoryLabel[doc.data.category]}</span>
        <h1>{doc.data.title}</h1>
        <time>{formatDate(doc.data.date)}</time>
      </header>
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .doc-container {
    max-width: 820px;
  }

  .doc-back {
    font-size: 13px;
    color: var(--green);
    letter-spacing: 0.08em;
  }

  .doc-back:hover {
    text-decoration: underline;
  }

  .doc-header {
    margin: 28px 0 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line);
  }

  .doc-header h1 {
    font-size: 28px;
    margin: 16px 0 12px;
  }

  .doc-header time {
    font-family: var(--font-en);
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  @media (max-width: 768px) {
    .doc-header h1 {
      font-size: 22px;
    }
  }
</style>
