---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase, formatDate } from '../../lib/paths';

const categoryLabel: Record<string, string> = {
  manual: 'マニュアル',
  case: '導入事例',
  news: 'お知らせ',
};

const docs = (await getCollection('docs')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// ヒーローのスペックチップ（3-in-1 Portable CNC の主要スペック）
const specChips = [
  { value: '約4kg', unit: '9 lb', label: '持ち運べる軽さ' },
  { value: "4'×8'", unit: '1220×2440mm', label: '大判の加工エリア' },
  { value: '1.2in', unit: '約30mm', label: '切削深さ' },
];

const features = [
  {
    no: '01',
    title: '3-in-1、これ一台で。',
    text: '切削・彫刻・彫り込みをワンマシンで。刃と設定を替えるだけで、看板づくりから精密な部品加工まで守備範囲が広がります。',
  },
  {
    no: '02',
    title: '現場に、持ち出せる。',
    text: '約4kgのポータブル設計。Makita 18V充電式ルーターで駆動するため、電源のない場所や教室の机の上でも動かせます。',
  },
  {
    no: '03',
    title: '教室に、ちょうどいい。',
    text: '教育向けエディション「GORDIX STUDENT」を用意。はじめて機械に触れる生徒でも扱いやすい安全設計と、授業用の教材が揃います。',
  },
];

// 主なスペック（3-in-1 Portable CNC）※製品構成により異なる場合あり
const specs = [
  { dt: '加工モード', dd: '3-in-1（切削 / 彫刻 / 彫り込み）' },
  { dt: '加工エリア', dd: "4' × 8'（約 1,220 × 2,440 mm）" },
  { dt: '切削深さ', dd: '最大 1.2 in（約 30 mm）' },
  { dt: '重量', dd: '約 4 kg（9 lb）' },
  { dt: '駆動', dd: 'Makita 18V 充電式ルーター対応（コードレス）' },
  { dt: '対応素材', dd: '木材・合板・MDF・アクリル 等' },
];

// 導入事例・お知らせはダミー。正式運用時に差し替え
const cases = [
  {
    date: '2026.06.15',
    tag: '導入事例',
    title: '県立高校の探究学習にGORDIXを導入（サンプル）',
    image: withBase('/images/gordix/case-01.png'),
  },
  {
    date: '2026.05.28',
    tag: '導入事例',
    title: '公共図書館のものづくりスペースで稼働開始（サンプル）',
    image: withBase('/images/gordix/case-02.png'),
  },
  {
    date: '2026.05.01',
    tag: 'お知らせ',
    title: 'GORDIX体験会を毎月開催しています（サンプル）',
    image: withBase('/images/gordix/case-03.png'),
  },
];
---

<BaseLayout
  theme="dark"
  title="GORDIX｜3-in-1 ポータブルCNC - KIILA株式会社"
  description="GORDIXは、切削・彫刻・彫り込みを1台でこなす3-in-1のポータブルCNCです。約4kg・充電式ルーター駆動で、教育機関の教室から工房まで。KIILAが導入支援・ドキュメント整備・コミュニティ運営で普及を進めます。"
>
  <!-- ヒーロー -->
  <section class="gordix-hero">
    <div class="container gordix-hero-inner">
      <div class="gordix-hero-copy">
        <img class="gordix-logo" src={withBase('/images/gordix/gordix-logo.svg')} alt="GORDIX" />
        <p class="gordix-badge">3-in-1 PORTABLE CNC</p>
        <h1 class="gordix-hero-title">
          <span class="accent">削る</span>を、<br />
          机の上に。
        </h1>
        <p class="gordix-hero-lead">
          切削・彫刻・彫り込みを1台で。約4kgのポータブルCNC「GORDIX」が、
          教室から工房まで、デジタルものづくりのすそ野を広げます。
        </p>
        <div class="spec-chips">
          {
            specChips.map((c) => (
              <div class="spec-chip">
                <span class="spec-chip-value">{c.value}</span>
                <span class="spec-chip-unit">{c.unit}</span>
                <span class="spec-chip-label">{c.label}</span>
              </div>
            ))
          }
        </div>
        <div class="gordix-hero-buttons">
          <a class="btn" href="#contact">導入相談・資料請求</a>
          <a class="btn btn-outline" href="#docs">ドキュメントを見る</a>
        </div>
      </div>
      <div class="gordix-hero-visual">
        <img src={withBase('/images/gordix/hero.png')} alt="3-in-1 ポータブルCNC GORDIX" />
      </div>
    </div>
  </section>

  <!-- 特徴 -->
  <section class="section">
    <div class="container">
      <p class="section-eyebrow">Features</p>
      <h2 class="section-title">GORDIXの特徴</h2>
      <div class="feature-grid">
        {
          features.map((f) => (
            <div class="card feature-card">
              <p class="feature-number">{f.no}</p>
              <h3>{f.title}</h3>
              <p class="feature-text">{f.text}</p>
            </div>
          ))
        }
      </div>
      <div class="machine-grid">
        <img src={withBase('/images/gordix/machine.png')} alt="GORDIX本体" />
        <div>
          <h3 class="machine-title">主なスペック</h3>
          <dl class="spec-list">
            {
              specs.map((s) => (
                <div>
                  <dt>{s.dt}</dt>
                  <dd>{s.dd}</dd>
                </div>
              ))
            }
          </dl>
          <p class="spec-note">※ 仕様は製品構成により異なる場合があります。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ドキュメント／ノウハウ -->
  <section class="section section-alt" id="docs">
    <div class="container">
      <p class="section-eyebrow">Documents</p>
      <h2 class="section-title">ドキュメント／ノウハウ</h2>
      <p class="section-lead">
        GORDIXのセットアップから活用ノウハウ、導入事例までを随時公開しています。
      </p>
      <ul class="doc-list">
        {
          docs.map((doc) => (
            <li>
              <a class="doc-item" href={withBase(`/gordix/docs/${doc.id}/`)}>
                <span class="tag tag-green">{categoryLabel[doc.data.category]}</span>
                <span class="doc-item-main">
                  <span class="doc-item-title">{doc.data.title}</span>
                  <span class="doc-item-desc">{doc.data.description}</span>
                </span>
                <time class="doc-item-date">{formatDate(doc.data.date)}</time>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 教育機関向けプログラム（GORDIX STUDENT） -->
  <section class="section" id="education">
    <div class="container edu-grid">
      <div>
        <p class="section-eyebrow">GORDIX STUDENT</p>
        <h2 class="section-title">教育機関向け導入プログラム</h2>
        <p class="edu-lead">
          「つくりたい」を、カリキュラムに。探究学習・ものづくり教育の現場で、
          GORDIXは生徒のアイデアをかたちにする道具になります。
        </p>
        <ul class="edu-list">
          <li>
            <strong>探究学習での活用</strong>
            地域材を使ったプロダクト開発など、課題設定から製作・発表までを一貫して体験できます。
          </li>
          <li>
            <strong>教員向け研修</strong>
            操作研修に加え、授業案・安全指導のテンプレートを提供。初年度は伴走サポート付きです。
          </li>
          <li>
            <strong>保守・サポート</strong>
            国内サポート窓口による定期メンテナンスと消耗品供給で、長く安心して使えます。
          </li>
        </ul>
      </div>
      <img src={withBase('/images/gordix/education.png')} alt="教室でGORDIXを使う様子" />
    </div>
  </section>

  <!-- 導入事例・お知らせ -->
  <section class="section section-alt" id="cases">
    <div class="container">
      <p class="section-eyebrow">Cases & News</p>
      <h2 class="section-title">導入事例・お知らせ</h2>
      <div class="case-grid">
        {
          cases.map((item) => (
            <article class="case-card">
              <img src={item.image} alt="" />
              <div class="case-body">
                <span class="tag">{item.tag}</span>
                <p class="case-title">{item.title}</p>
                <time class="case-date">{item.date}</time>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 問い合わせ・資料請求 -->
  <section class="section" id="contact">
    <div class="container contact-inner">
      <p class="section-eyebrow">Contact</p>
      <h2 class="section-title">お問い合わせ・資料請求</h2>
      <p class="section-lead">
        導入のご相談、デモ見学、資料請求など、お気軽にお問い合わせください。
      </p>
      <!-- ダミーフォーム：送信処理は未実装。フォームサービス接続時に action を差し替える -->
      <form class="contact-form" id="contact-form">
        <div class="form-row">
          <label>
            お名前 <span class="required">必須</span>
            <input type="text" name="name" placeholder="山田 太郎" required />
          </label>
          <label>
            ご所属（学校・団体・会社名）
            <input type="text" name="organization" placeholder="○○高等学校" />
          </label>
        </div>
        <div class="form-row">
          <label>
            メールアドレス <span class="required">必須</span>
            <input type="email" name="email" placeholder="taro@example.com" required />
          </label>
          <label>
            お問い合わせ種別
            <select name="type">
              <option>資料請求</option>
              <option>導入相談</option>
              <option>デモ見学の希望</option>
              <option>その他</option>
            </select>
          </label>
        </div>
        <label>
          お問い合わせ内容
          <textarea name="message" rows="6" placeholder="ご検討状況やご質問をご記入ください"></textarea>
        </label>
        <p class="form-note">※ 現在このフォームは準備中のため、送信は行われません。</p>
        <button class="btn" type="submit">送信する</button>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  // ダミーフォーム：送信を止めてメッセージだけ表示する
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('このフォームは準備中のダミーです。送信は行われませんでした。');
  });
</script>

<style>
  /* ---------- ヒーロー ---------- */
  .gordix-hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(120% 80% at 78% 30%, rgba(238, 119, 51, 0.16) 0%, rgba(238, 119, 51, 0) 55%),
      linear-gradient(135deg, #1b2026 0%, #131619 55%, #0d1013 100%);
  }

  /* 上端にオレンジのアクセントライン */
  .gordix-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--green) 0%, rgba(238, 119, 51, 0) 60%);
  }

  .gordix-hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 56px;
    padding-block: 88px;
  }

  .gordix-logo {
    width: 168px;
    height: auto;
    margin-bottom: 24px;
  }

  .gordix-badge {
    display: inline-block;
    font-family: var(--font-en);
    font-size: 12px;
    letter-spacing: 0.32em;
    color: var(--green);
    border: 1px solid rgba(238, 119, 51, 0.5);
    border-radius: 3px;
    padding: 5px 12px;
    margin-bottom: 22px;
  }

  .gordix-hero-title {
    font-size: clamp(34px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0.06em;
  }

  .gordix-hero-title .accent {
    color: var(--green);
  }

  .gordix-hero-lead {
    margin-top: 24px;
    color: var(--muted);
    max-width: 520px;
  }

  /* スペックチップ */
  .spec-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .spec-chip {
    display: flex;
    flex-direction: column;
    padding: 14px 20px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--line);
    border-radius: 8px;
    min-width: 120px;
  }

  .spec-chip-value {
    font-family: var(--font-en);
    font-size: 24px;
    font-weight: 600;
    color: var(--green);
    letter-spacing: 0.02em;
  }

  .spec-chip-unit {
    font-family: var(--font-en);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin-top: 2px;
  }

  .spec-chip-label {
    font-size: 12px;
    color: var(--ink);
    margin-top: 8px;
  }

  .gordix-hero-buttons {
    margin-top: 34px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .gordix-hero-visual {
    position: relative;
  }

  .gordix-hero-visual img {
    border-radius: var(--radius);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    clip-path: polygon(8% 0, 100% 0, 100% 100%, 0 100%);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
  }

  /* ---------- 特徴 ---------- */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 24px;
  }

  .feature-card {
    border: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--green);
  }

  .feature-number {
    font-family: var(--font-en);
    font-size: 15px;
    letter-spacing: 0.2em;
    color: var(--green);
    margin-bottom: 12px;
  }

  .feature-card h3 {
    font-size: 18px;
    margin-bottom: 12px;
  }

  .feature-text {
    font-size: 13px;
    color: var(--muted);
  }

  .machine-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    margin-top: 64px;
  }

  .machine-grid img {
    border-radius: var(--radius);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    border: 1px solid var(--line);
  }

  .machine-title {
    font-size: 19px;
    margin-bottom: 20px;
    padding-left: 14px;
    border-left: 3px solid var(--green);
  }

  .spec-list {
    margin: 0;
  }

  .spec-list div {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 16px;
    padding: 13px 4px;
    border-bottom: 1px solid var(--line);
    font-size: 14px;
  }

  .spec-list dt {
    color: var(--muted);
  }

  .spec-list dd {
    margin: 0;
  }

  .spec-note {
    font-size: 12px;
    color: var(--muted);
    margin-top: 16px;
  }

  /* ---------- ドキュメント ---------- */
  .doc-list {
    list-style: none;
    margin: 32px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .doc-item {
    display: flex;
    align-items: center;
    gap: 22px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px 28px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .doc-item:hover {
    transform: translateY(-2px);
    border-color: var(--green);
  }

  .doc-item .tag {
    flex-shrink: 0;
  }

  .doc-item-main {
    flex: 1;
    min-width: 0;
  }

  .doc-item-title {
    display: block;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .doc-item-desc {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
  }

  .doc-item-date {
    flex-shrink: 0;
    font-family: var(--font-en);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  /* ---------- 教育機関向け ---------- */
  .edu-grid {
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    gap: 56px;
    align-items: center;
  }

  .edu-lead {
    color: var(--muted);
    margin-bottom: 28px;
  }

  .edu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .edu-list li {
    background: var(--card);
    border: 1px solid var(--line);
    border-left: 4px solid var(--green);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 18px 24px;
    font-size: 14px;
    color: var(--muted);
  }

  .edu-list strong {
    display: block;
    color: var(--ink);
    margin-bottom: 4px;
    letter-spacing: 0.08em;
  }

  .edu-grid > img {
    border-radius: var(--radius);
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    border: 1px solid var(--line);
  }

  /* ---------- 導入事例 ---------- */
  .case-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 24px;
  }

  .case-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .case-card img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
  }

  .case-body {
    padding: 18px 20px 22px;
  }

  .case-title {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.8;
    margin-top: 10px;
  }

  .case-date {
    display: block;
    font-family: var(--font-en);
    font-size: 12px;
    color: var(--muted);
    margin-top: 10px;
    letter-spacing: 0.08em;
  }

  /* ---------- フォーム ---------- */
  .contact-inner {
    max-width: 760px;
  }

  .contact-form {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .required {
    display: inline-block;
    background: var(--green);
    color: #fff;
    font-size: 10px;
    padding: 1px 8px;
    border-radius: 3px;
    margin-left: 6px;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    font-family: var(--font-jp);
    font-size: 14px;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg-soft);
    color: var(--ink);
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: #6b7178;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: 2px solid var(--green);
    outline-offset: 1px;
    border-color: var(--green);
  }

  .form-note {
    font-size: 12px;
    color: var(--muted);
  }

  .contact-form .btn {
    align-self: flex-start;
  }

  /* ---------- レスポンシブ ---------- */
  @media (max-width: 960px) {
    .gordix-hero-inner {
      grid-template-columns: 1fr;
      padding-block: 56px;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .machine-grid,
    .edu-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .case-grid {
      grid-template-columns: 1fr;
    }

    .doc-item {
      flex-wrap: wrap;
      gap: 12px;
    }

    .doc-item-main {
      flex-basis: 100%;
      order: 3;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .spec-chip {
      flex: 1;
      min-width: 0;
    }
  }
</style>
