---
import { withBase } from '../lib/paths';

const nav = [
  { href: withBase('/#about'), label: '事業概要' },
  { href: withBase('/mokuri/'), label: 'MOKURI' },
  { href: withBase('/gordix/'), label: 'GORDIX' },
  { href: withBase('/gordix/#docs'), label: 'ドキュメント' },
  { href: withBase('/#news'), label: 'お知らせ' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={withBase('/')}>
      <span class="brand-logo">KIILA</span>
      <span class="brand-name">KIILA株式会社</span>
    </a>

    <button class="nav-toggle" type="button" aria-label="メニューを開閉する" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="global-nav" id="global-nav">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a class="btn btn-nav" href={withBase('/gordix/#contact')}>相談する</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('global-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
  // ナビ内リンクをタップしたらメニューを閉じる（スマホ用）
  nav?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    max-width: 1240px;
    margin-inline: auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .brand-logo {
    font-family: var(--font-en);
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: var(--green);
  }

  .brand-name {
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--ink);
  }

  .global-nav {
    display: flex;
    align-items: center;
    gap: 30px;
    font-size: 13px;
    letter-spacing: 0.1em;
  }

  .global-nav a:not(.btn) {
    padding-block: 6px;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .global-nav a:not(.btn):hover {
    color: var(--green);
    border-bottom-color: var(--green);
  }

  .btn-nav {
    padding: 10px 22px;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    padding: 9px;
    background: none;
    border: 1px solid var(--line);
    border-radius: 6px;
    cursor: pointer;
  }

  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--ink);
  }

  @media (max-width: 900px) {
    .nav-toggle {
      display: flex;
    }

    .global-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: #fff;
      border-bottom: 1px solid var(--line);
      padding: 12px 24px 24px;
    }

    .global-nav.is-open {
      display: flex;
    }

    .global-nav a:not(.btn) {
      padding: 14px 4px;
      border-bottom: 1px solid var(--line);
    }

    .btn-nav {
      margin-top: 18px;
      justify-content: center;
    }
  }
</style>
