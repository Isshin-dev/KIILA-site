---
import { withBase } from '../lib/paths';

const nav = [
  { href: withBase('/#about'), label: '事業概要' },
  { href: withBase('/mokuri/'), label: 'MOKURI' },
  { href: withBase('/gordix/'), label: 'GORDIX' },
  { href: withBase('/gordix/#docs'), label: 'ドキュメント' },
  { href: withBase('/#news'), label: 'お知らせ' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={withBase('/')} aria-label="KIILA ホーム">KIILA</a>

    <nav class="global-nav" id="global-nav">
      {nav.map((item) => <a class="nav-link" href={item.href}>{item.label}</a>)}
    </nav>

    <div class="header-actions">
      <a class="btn btn-secondary btn-sm" href={withBase('/gordix/#contact')}>お問い合わせ</a>
      <a class="btn btn-primary btn-sm" href={withBase('/gordix/#contact')}>相談する</a>
      <button class="nav-toggle" type="button" aria-label="メニューを開閉する" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" id="mobile-nav">
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const mobile = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = mobile?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
  mobile?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).tagName === 'A') {
      mobile.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--canvas);
    border-bottom: 1px solid var(--hairline);
  }

  .header-inner {
    max-width: 1280px;
    margin-inline: auto;
    height: 64px;
    padding-inline: 32px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .brand {
    font-family: var(--font-sans);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .global-nav {
    display: flex;
    align-items: center;
    gap: 26px;
    margin-right: auto;
  }

  .nav-link {
    font-size: 16px;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .nav-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .btn-sm {
    font-size: 15px;
    min-height: 40px;
    padding: 8px 18px;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 10px;
    background: var(--surface-soft);
    border: none;
    border-radius: var(--r-full);
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    height: 1.5px;
    background: var(--ink);
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px 32px 24px;
    border-bottom: 1px solid var(--hairline);
  }
  .mobile-nav a {
    padding: 14px 0;
    font-size: 18px;
    border-bottom: 1px solid var(--hairline-soft);
  }
  .mobile-nav.is-open {
    display: flex;
  }

  @media (max-width: 960px) {
    .global-nav {
      display: none;
    }
    .header-inner {
      justify-content: space-between;
      gap: 12px;
    }
    .nav-toggle {
      display: flex;
    }
  }

  @media (max-width: 560px) {
    .header-inner {
      padding-inline: 24px;
    }
    /* 狭幅ではセカンダリを隠してプライマリ＋ハンバーガーを残す */
    .header-actions .btn-secondary {
      display: none;
    }
  }
</style>
